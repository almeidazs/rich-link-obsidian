{
	"compilerOptions": {
		"lib": ["DOM", "ES2020"],
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"types": ["obsidian"],
	},
	"include": ["src/**/*.ts"],
}
